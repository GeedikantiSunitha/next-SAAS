# ============================================
# NextSaaS Frontend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control
# Note: Vite requires VITE_ prefix for all variables

# ============================================
# REQUIRED - API Configuration
# ============================================
# Backend API base URL
VITE_API_BASE_URL=http://localhost:3001
VITE_API_TIMEOUT=10000

# ============================================
# OPTIONAL - App Configuration
# ============================================
VITE_APP_NAME=NextSaaS

# ============================================
# OPTIONAL - OAuth Providers (Client IDs)
# ============================================
# These are PUBLIC client IDs (safe to expose in frontend)
# Get these from your OAuth provider settings

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=

# GitHub OAuth Client ID
VITE_GITHUB_CLIENT_ID=

# Microsoft OAuth Client ID
VITE_MICROSOFT_CLIENT_ID=
VITE_MICROSOFT_TENANT_ID=common

# ============================================
# OPTIONAL - Payment (Stripe)
# ============================================
# Get publishable key from: https://dashboard.stripe.com/apikeys
# This is a PUBLIC key (safe to expose in frontend)
VITE_STRIPE_PUBLISHABLE_KEY=

# ============================================
# OPTIONAL - Monitoring (Sentry)
# ============================================
# Get DSN from: https://sentry.io/settings/projects/
# This is a PUBLIC DSN (safe to expose in frontend)
VITE_SENTRY_DSN=

# ============================================
# OPTIONAL - Feature Flags
# ============================================
VITE_ENABLE_REGISTRATION=true
VITE_ENABLE_PASSWORD_RESET=true
