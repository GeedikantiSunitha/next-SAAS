  "syncStrategies": {
    "git-based": {
      "command": "git cherry-pick",
      "pros": ["Version control", "Easy rollback", "Clear history"],
      "cons": ["Requires conflict resolution"]
    },
    "file-copy": {
      "command": "cp",
      "pros": ["Simple", "No Git conflicts"],
      "cons": ["No version control", "Can overwrite changes"]
    },
    "package-based": {
      "command": "npm update",
      "pros": ["Clean", "Versioned", "Selective updates"],
      "cons": ["Requires setup", "More infrastructure"]
    }
  },

