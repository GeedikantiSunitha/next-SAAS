  "syncBehaviors": {
    "replace": {
      "description": "Completely replace file in product with template version",
      "risk": "low",
      "recommendation": "Safe for core compliance features that shouldn't be customized"
    },
    "merge": {
      "description": "Merge changes carefully, preserving product customizations",
      "risk": "medium",
      "recommendation": "Use for UI components and shared services"
    },
    "review": {
      "description": "Review all changes manually before applying",
      "risk": "medium-high",
      "recommendation": "Use for security configs and middleware"
    },
    "skip": {
      "description": "Do not sync - product-specific",
      "risk": "none",
      "recommendation": "Use for auth, business logic, custom features"
    },
    "selective": {
      "description": "Sync only specific parts (e.g., certain migrations)",
      "risk": "medium",
      "recommendation": "Use for database migrations"
    },
    "template": {
      "description": "Use template as starting point, then customize",
      "risk": "low",
      "recommendation": "Use for legal documents"
    }
  },

  "conflictLevels": {
    "none": "No conflicts expected",
    "low": "Minimal conflicts, easy to resolve",
    "medium": "Some conflicts, may need manual review",
    "high": "Significant conflicts, careful merging required",
    "very-high": "Extensive conflicts, may be easier to skip and rewrite"
  },

