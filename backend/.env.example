# ============================================
# NextSaaS Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control

# ============================================
# REQUIRED - Server Configuration
# ============================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ============================================
# REQUIRED - Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nextsaas_db

# ============================================
# REQUIRED - JWT Authentication
# ============================================
# Generate secure random strings (minimum 32 characters)
# You can use: openssl rand -base64 32
JWT_SECRET=your-secret-key-minimum-32-characters-long-change-this
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters-long-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# OPTIONAL - Cookie Configuration
# ============================================
# For production, set these values:
# COOKIE_DOMAIN=.yourdomain.com
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=strict
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ============================================
# OPTIONAL - Email Configuration (Resend)
# ============================================
# Get your API key from https://resend.com
# Email functionality requires this to be set
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
APP_NAME=NextSaaS

# ============================================
# OPTIONAL - OAuth Providers
# ============================================
# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft OAuth
# Get credentials from: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ============================================
# OPTIONAL - Payment Providers
# ============================================
# Choose one: STRIPE, RAZORPAY, or CASHFREE
PAYMENT_PROVIDER=STRIPE
PAYMENT_MODE=test

# Stripe Configuration
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay Configuration
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cashfree Configuration
# Get keys from: https://www.cashfree.com/developers/api/credentials
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_MODE=test
CASHFREE_WEBHOOK_SECRET=

# ============================================
# OPTIONAL - Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ============================================
# OPTIONAL - Logging
# ============================================
LOG_LEVEL=info

# ============================================
# OPTIONAL - Feature Flags
# ============================================
ENABLE_REGISTRATION=true
ENABLE_PASSWORD_RESET=true
ENABLE_EMAIL_VERIFICATION=false

# ============================================
# OPTIONAL - Monitoring (Sentry)
# ============================================
# Get DSN from: https://sentry.io/settings/projects/
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# OPTIONAL - API Documentation
# ============================================
# Set to true to enable Swagger UI in production
ENABLE_SWAGGER=false

# ============================================
# OPTIONAL - Architecture Mode
# ============================================
# Options: monolith, microservices
ARCHITECTURE_MODE=monolith
